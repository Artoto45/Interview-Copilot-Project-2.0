# ============================================================
# Interview Copilot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.
# ============================================================

# --- Anthropic (Claude Opus 4.6 Thinking + Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Deepgram (Real-time Transcription) ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- OpenAI (Embeddings: text-embedding-3-small) ---
OPENAI_API_KEY=sk-...

# --- Voicemeeter Banana (Audio Routing) ---
VOICEMEETER_DEVICE_USER=VoiceMeeter Out B1
VOICEMEETER_DEVICE_INT=VoiceMeeter Out B2

# --- Server Configuration ---
HOST=127.0.0.1
PORT=8000

# --- Audio Settings ---
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_MS=100

# --- Teleprompter Settings ---
TELEPROMPTER_WPM=130
TELEPROMPTER_OPACITY=0.80
TELEPROMPTER_FONT_SIZE=28
