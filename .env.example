# ============================================================
# Interview Copilot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.
# ============================================================

# --- Anthropic (Claude Opus 4.6 Thinking + Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional (required for live /organizations/cost_report refresh):
# ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# --- Deepgram (Real-time Transcription) ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# DEEPGRAM_PROJECT_ID=your_deepgram_project_id_here

# --- OpenAI (Embeddings: text-embedding-3-small) ---
OPENAI_API_KEY=sk-...
# Optional (required for live /organization/costs refresh):
# OPENAI_ADMIN_KEY=sk-admin-...

# --- Google (Gemini fallback/experiments) ---
GOOGLE_API_KEY=AIza...

# --- Voicemeeter Banana (Audio Routing) ---
VOICEMEETER_DEVICE_USER=VoiceMeeter Out B1
VOICEMEETER_DEVICE_INT=VoiceMeeter Out B2

# --- Server Configuration ---
HOST=127.0.0.1
PORT=8000

# --- Audio Settings ---
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_MS=100

# --- Teleprompter Settings ---
TELEPROMPTER_WPM=130
TELEPROMPTER_OPACITY=0.80
TELEPROMPTER_FONT_SIZE=28

# --- VibeVoice (Optional Microsoft Realtime TTS) ---
VIBEVOICE_ENABLED=false
VIBEVOICE_REPO_URL=https://github.com/microsoft/VibeVoice.git
VIBEVOICE_REPO_PATH=external/VibeVoice
VIBEVOICE_MODEL_PATH=microsoft/VibeVoice-Realtime-0.5B
VIBEVOICE_DEVICE=cuda
VIBEVOICE_HOST=127.0.0.1
VIBEVOICE_PORT=3000
VIBEVOICE_AUTO_CLONE=true
VIBEVOICE_AUTO_INSTALL=false
# Optional override python executable for installer/runtime
# VIBEVOICE_PYTHON=C:\\Python313\\python.exe

# --- Saldo (Initial Credit Balances in USD) ---
SALDO_OPENAI_USD=9.92
SALDO_DEEPGRAM_USD=188.69
SALDO_ANTHROPIC_USD=4.74

# --- Saldo Live Refresh (optional) ---
SALDO_ENABLE_LIVE_REFRESH=false
SALDO_REFRESH_INTERVAL_S=120
# Baseline timestamp when SALDO_* balances were captured.
# Live cost APIs subtract spend since this instant.
# SALDO_BASELINE_START_UTC=2026-03-03T00:00:00Z
SALDO_LIVE_OPENAI_ENABLED=true
SALDO_LIVE_ANTHROPIC_ENABLED=true

# --- Fuel Gauge Profile ---
# If Anthropic is not used in your runtime, set this to false.
SALDO_OPENAI_GENERATION_ACTIVE=true
SALDO_ANTHROPIC_GENERATION_ACTIVE=true

# --- Optional Cost Override Rates ---
# COST_OPENAI_REALTIME_AUDIO_PER_MINUTE=0.020
# COST_DEEPGRAM_REALTIME_AUDIO_PER_MINUTE=0.0043
# COST_OPENAI_EMBEDDING_INPUT_PER_1M=0.020
# COST_OPENAI_GPT4O_MINI_INPUT_PER_1M=0.15
# COST_OPENAI_GPT4O_MINI_OUTPUT_PER_1M=0.60
# COST_CLAUDE_INPUT_PER_1M=3.0
# COST_CLAUDE_OUTPUT_PER_1M=15.0
# COST_CLAUDE_CACHE_WRITE_PER_1M=3.75
# COST_CLAUDE_CACHE_READ_PER_1M=0.30
# COST_GEMINI_INPUT_PER_1M=1.25
# COST_GEMINI_OUTPUT_PER_1M=5.0
